{
  "name": "rocketmq/rocketmq-php-sdk",
  "description": "PHP SDK for Apache RocketMQ",
  "license": "Apache-2.0",
  "require": {
    "google/protobuf": "^3.3",
    "grpc/grpc": "^1.80",
    "hanson/foundation-sdk": "^5.0"
  },
  "autoload": {
    "psr-4": {
      "GPBMetadata\\": "grpc/GPBMetadata",
      "Apache\\Rocketmq\\V2\\": "grpc/Apache/Rocketmq/V2",
      "Apache\\Rocketmq\\": "."
    },
    "classmap": [
      "HealthChecker.php",
      "MessageInterceptor.php",
      "MetricsCollector.php",
      "Consumer.php",
      "Producer.php",
      "Attribute.php",
      "AttributeKey.php",
      "MessageInterceptorContextInterface.php",
      "MessageInterceptorContextImpl.php",
      "MessageHookPoints.php",
      "MessageHookPointsStatus.php",
      "CompositedMessageInterceptor.php",
      "LoggingMessageInterceptor.php",
      "MessageMeterInterceptor.php",
      "ClientMeterManager.php",
      "MetricsSupportTrait.php",
      "TelemetrySession.php",
      "SwooleAsyncSupport.php",
      "ClientSettings.php",
      "PublishingSettings.php",
      "PushSubscriptionSettings.php",
      "HistogramEnum.php",
      "GaugeEnum.php",
      "InvocationStatus.php"
    ]
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0"
  }
}
