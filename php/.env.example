# RocketMQ Configuration Example
# Copy this file to .env and fill in your actual values

# RocketMQ server endpoints
ROCKETMQ_ENDPOINTS=127.0.0.1:8080

# Access credentials (optional, leave empty if not using authentication)
ROCKETMQ_ACCESS_KEY=your_access_key_here
ROCKETMQ_SECRET_KEY=your_secret_key_here

# Namespace (optional)
ROCKETMQ_NAMESPACE=

# SSL configuration
ROCKETMQ_SSL_ENABLED=false
